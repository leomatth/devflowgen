{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["app/api/**/*.ts", "lib/ai/**/*.ts", "types/**/*.ts", "types/**/*.d.ts"]
}
